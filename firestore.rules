rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Easy Green – Yardstick Lawn Care Tracker
// Firestore Security Rules
//
// Collections used by this app
// ─────────────────────────────────────────────────────────────────────────────
//
//  ROOT COLLECTIONS
//  ─────────────────────────────────────────────────────────────────────────
//  gallery        Community photo feed. Logged-in users can read all photos
//                 and upload their own. Only the uploader (or admin) can delete.
//
//  feedback       Bug reports, feature requests, and contact form submissions.
//                 Anyone (including unauthenticated visitors) can create — keeps
//                 friction low for bug reports. Admin-only for reads + status updates.
//
//  proInterest    Pro plan waitlist signups. Anyone can submit an email.
//                 Admin-only reads.
//
//  USER SUBCOLLECTIONS  (all under users/{uid})
//  ─────────────────────────────────────────────────────────────────────────
//  users/{uid}/activities        Activity log entries
//  users/{uid}/equipment/{id}    Equipment items + maintenance history
//  users/{uid}/profile/data      Lawn profile (grass type, zone, lot size, etc.)
//
// ─────────────────────────────────────────────────────────────────────────────
// To deploy
// ─────────────────────────────────────────────────────────────────────────────
//
//  Option A — Firebase Console (no CLI required):
//    1. Open Firebase Console → Firestore → Rules tab
//    2. Replace everything with these rules
//    3. Click Publish
//
//  Option B — Firebase CLI:
//    firebase deploy --only firestore:rules
//
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the caller the app admin? ──────────────────────────────────
    function isAdmin() {
      return request.auth != null
          && request.auth.token.email == 'yardsticklawncareapp@gmail.com';
    }

    // ── Helper: is the caller signed in? ─────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }


    // ═════════════════════════════════════════════════════════════════════════
    // GALLERY  –  /gallery/{photoId}
    // ═════════════════════════════════════════════════════════════════════════
    match /gallery/{photoId} {

      // Any signed-in user can browse the community feed
      allow read: if isSignedIn();

      // A signed-in user can add a photo only if they stamp it with their own uid
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      // Only the original uploader or the admin may remove a photo
      allow delete: if isSignedIn()
                    && (resource.data.userId == request.auth.uid || isAdmin());

      // Photos are immutable after upload — updates are not used
      allow update: if false;
    }


    // ═════════════════════════════════════════════════════════════════════════
    // USER PRIVATE DATA  –  /users/{userId}/**
    // ═════════════════════════════════════════════════════════════════════════
    // Covers every subcollection:
    //   users/{uid}/activities/{actId}
    //   users/{uid}/equipment/{eqId}
    //   users/{uid}/profile/data
    //
    // Each user may only access their own documents.
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn()
                         && request.auth.uid == userId;
    }


    // ═════════════════════════════════════════════════════════════════════════
    // FEEDBACK  –  /feedback/{docId}
    // ═════════════════════════════════════════════════════════════════════════
    match /feedback/{docId} {

      // Open to everyone — unauthenticated users can still file a bug report.
      // The client sends userId: null when not signed in; that is intentional.
      allow create: if true;

      // Admin can read all submissions and update their status field
      // (new → in-review → resolved → closed)
      allow read, update: if isAdmin();

      // No one may delete — keep an audit trail
      allow delete: if false;
    }


    // ═════════════════════════════════════════════════════════════════════════
    // PRO INTEREST / WAITLIST  –  /proInterest/{docId}
    // ═════════════════════════════════════════════════════════════════════════
    match /proInterest/{docId} {

      // Anyone can sign up, even without an account
      allow create: if true;

      // Admin-only reads so email list stays private
      allow read: if isAdmin();

      // Immutable once submitted
      allow update, delete: if false;
    }

  }
}
